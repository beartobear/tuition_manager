{
  "name": "quan-ly-hoc-phi",
  "version": "1.0.0",
  "description": "Quản lý học phí",  // ✅ NÊN THÊM description
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac"  // ✅ NÊN THÊM cho macOS
  },
  "build": {
    "appId": "com.tuition.manager",
    "productName": "QuanLyHocPhi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {  // ✅ NÊN THÊM cấu hình macOS
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true
    }
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  }
}
